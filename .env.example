# --- API keys (never commit real values) ---
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
EXA_API_KEY=
AGENTMAIL_API_KEY=

# --- OpenAI-compatible providers (LiteLLM picks these up automatically) ---
# Uncomment + fill in any of these to enable the matching vendor. LiteLLM
# expects specific variable names; see backend/config.py PROVIDER_KEYS for
# the full list.
#
# OpenAI direct
# OPENAI_API_KEY=
# OPENAI_ORGANIZATION=
# OPENAI_PROJECT=
#
# Anthropic direct
# ANTHROPIC_API_KEY=
#
# Groq
# GROQ_API_KEY=
#
# Together AI
# TOGETHERAI_API_KEY=
#
# Fireworks AI
# FIREWORKS_AI_API_KEY=
#
# Mistral
# MISTRAL_API_KEY=
#
# DeepSeek (OpenAI-compatible)
# DEEPSEEK_API_KEY=
#
# xAI / Grok (OpenAI-compatible)
# XAI_API_KEY=
#
# Perplexity (OpenAI-compatible)
# PERPLEXITY_API_KEY=
#
# Azure OpenAI
# AZURE_API_KEY=
# AZURE_API_BASE=https://YOUR-RESOURCE.openai.azure.com
# AZURE_API_VERSION=2024-08-01-preview
#
# Self-hosted / regional (point any vendor at a custom base URL):
# PROVIDER_API_BASE_OPENAI=http://localhost:11434/v1     # Ollama
# PROVIDER_API_BASE_GROQ=https://my-groq-proxy.internal   # private proxy
#
# --- API key overrides (for custom vendors OR when proxying a known vendor
# through your own endpoint that needs a different key) ---
# PROVIDER_API_KEY_OPENAI=sk-...                          # override OpenAI key
# PROVIDER_API_KEY_OLLAMA=sk-no-auth-needed               # any non-empty value
# PROVIDER_API_KEY_MYPROXY=...                            # for unknown vendors

# --- Folder where Agent 1 reads documents ---
DOCS_DIR=./docs

# --- Exa safety cap (hard guard inside the tool, mirrored in the agent's instruction) ---
MAX_EXA_CALLS=3

# --- AgentMail safety caps (hard guard inside the tool) ---
MAX_AGENTMAIL_CALLS=10
MAX_MESSAGES_PER_LIST=20
MAX_MESSAGE_PREVIEW_CHARS=2000

# --- Corpus safety caps (avoid context overflow) ---
MAX_CHARS_PER_FILE=10000
MAX_CORPUS_CHARS=120000

# --- Model routing (LiteLLM / OpenRouter compatible strings) ---
# Pick any LiteLLM-supported provider here. Examples:
#   MODEL_READER=openai/gpt-4o-mini
#   MODEL_READER=groq/llama-3.1-8b-instant
#   MODEL_READER=together_ai/meta-llama/Llama-3-70b-chat-hf
#   MODEL_READER=ollama/llama3.1                         # needs PROVIDER_API_BASE_OLLAMA
#   MODEL_READER=openai/llama-3.1-8b                    # + PROVIDER_API_BASE_OPENAI for Ollama
MODEL_READER=openrouter/openai/gpt-4o-mini
MODEL_ANALYST=openrouter/anthropic/claude-3.5-sonnet